# Supabase
# Werte aus dem Supabase-Dashboard → Project Settings → API
# Lokal: `pnpm exec supabase start` druckt die Werte am Ende der Ausgabe.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service-Role-Key — server-only, niemals an den Client geben.
# Wird gebraucht für: Invite-Code-Verbrauch, User-Anlage trotz enable_signup=false,
# Cron-Jobs (Schritt 6), Spotify-Owner-OAuth (Schritt 7).
SUPABASE_SECRET_KEY=

# Site URL — für Magic-Link-Redirects. In Prod (Vercel) auf https://<domain> setzen.
# Lokal optional; ohne wird der Host-Header benutzt.
NEXT_PUBLIC_SITE_URL=

# Spotify — Client-Credentials-Flow für die Track-Suche (Schritt 4).
# App im Spotify Developer Dashboard anlegen; Anleitung: docs/guides/spotify-setup.md.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Owner-OAuth-Refresh-Token (Schritt 7) — noch nicht benötigt.
# SPOTIFY_REFRESH_TOKEN=
