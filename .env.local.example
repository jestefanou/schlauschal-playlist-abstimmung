# Supabase
# Werte aus dem Supabase-Dashboard → Project Settings → API
# Lokal: `pnpm exec supabase start` druckt die Werte am Ende der Ausgabe.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service-Role-Key — server-only, niemals an den Client geben.
# Wird gebraucht für: Invite-Code-Verbrauch, User-Anlage trotz enable_signup=false,
# Cron-Jobs (Schritt 6), Spotify-Owner-OAuth (Schritt 7).
SUPABASE_SECRET_KEY=

# Site URL — für Magic-Link-Redirects. In Prod (Vercel) auf https://<domain> setzen.
# Lokal optional; ohne wird der Host-Header benutzt.
NEXT_PUBLIC_SITE_URL=

# Spotify — Client-Credentials-Flow für die Track-Suche (Schritt 4) und
# Owner-OAuth (Schritt 7). App im Spotify Developer Dashboard anlegen;
# Anleitung: docs/guides/spotify-setup.md. Der Owner-Refresh-Token liegt NICHT
# hier, sondern im Supabase Vault (verbinden über /admin/spotify) — dafür muss
# im Dashboard die Redirect URI <origin>/api/spotify/callback registriert sein.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Cron-Auth (Schritt 6) — schützt /api/cron/* gegen fremde Aufrufe.
# Vercel schickt den Wert automatisch als "Authorization: Bearer <CRON_SECRET>"
# mit, wenn die Env-Var im Projekt gesetzt ist. Lokal: beliebigen Wert setzen
# (z.B. `openssl rand -hex 32`) und beim curl-Test denselben Header mitgeben.
CRON_SECRET=
